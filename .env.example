# Backend
MEDBOT_DB_PATH=backend/medbot-demo.db
AGENT_BASE_URL=http://localhost:8011
AGENT_TOKEN=

# Email (Exchange EWS)
MEDBOT_EMAIL_SERVER=mail.microport.com.cn
MEDBOT_EMAIL_USER=
MEDBOT_EMAIL_PASSWORD=

# Agent sidecar
PI_PROVIDER=openai
OPENAI_API_KEY=
# For DeepSeek, set PI_PROVIDER=deepseek and use DEEPSEEK_API_KEY instead.
DEEPSEEK_API_KEY=
PI_MODEL=gpt-5-mini
BACKEND_BASE_URL=http://localhost:8000
AGENT_HOST=127.0.0.1
AGENT_PORT=8011
AGENT_CORS_ORIGIN=http://localhost:5173
AGENT_MAX_BODY_BYTES=65536
AGENT_MAX_SESSIONS=20
AGENT_SESSION_IDLE_MS=1800000

# Frontend
VITE_API_BASE_URL=http://localhost:8000
