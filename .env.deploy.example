# Copy this file to .env for Docker Compose deployment.

# Public ports on the host machine.
FRONTEND_PORT=5173
BACKEND_PORT=8000
PUBLIC_ORIGIN=http://localhost:5173

# Backend container runtime.
MEDBOT_DB_PATH=/data/medbot.db
AGENT_BASE_URL=http://agent:8011
AGENT_ENV_PATH=/app/agent/.env
AGENT_TOKEN=

# Email (Exchange EWS)
MEDBOT_EMAIL_SERVER=mail.microport.com.cn
MEDBOT_EMAIL_USER=
MEDBOT_EMAIL_PASSWORD=

# Frontend production build. The compose file builds the browser bundle with /api.
VITE_API_BASE_URL=/api
